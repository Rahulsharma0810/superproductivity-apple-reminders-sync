{
  "id": "sync-reminders",
  "manifestVersion": 1,
  "name": "Apple Reminders Sync",
  "version": "1.0.0",
  "description": "Bidirectional sync between SuperProductivity and Apple Reminders (via the remi CLI). macOS + desktop only.",
  "author": "SuperProductivity Community",
  "homepage": "https://github.com/super-productivity/super-productivity",
  "repository": {
    "type": "git",
    "url": "https://github.com/super-productivity/super-productivity.git"
  },
  "minSupVersion": "10.0.0",
  "permissions": [
    "getTasks",
    "updateTask",
    "addTask",
    "deleteTask",
    "getAllProjects",
    "getAllTags",
    "nodeExecution",
    "persistDataSynced",
    "loadSyncedData",
    "reorderTasks",
    "registerHook",
    "onMessage",
    "showSnack",
    "notify",
    "batchUpdateForProject"
  ],
  "nodeScriptConfig": {
    "timeout": 30000,
    "memoryLimit": "256MB"
  },
  "supportsIndexHtml": true,
  "iFrame": true,
  "isSkipMenuEntry": false,
  "hooks": ["anyTaskUpdate"],
  "icon": "icon.svg"
}
